{
  "version": 2,
  "builds": [
    {
      "src": "apps/site/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/site/$1"
    }
  ],
  "buildCommand": "cd apps/site && npm run build",
  "devCommand": "cd apps/site && npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": "apps/site/.next"
}
